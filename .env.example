# ─────────────────────────────────────────────────────────────
# Avis Budget Group — Live Reporting Dashboard
# Copy to .env.local for local dev; set the same keys in Netlify for production.
# The app runs with SAMPLE DATA across all three platforms when keys are absent,
# so you can build and click through everything before wiring real credentials.
# ─────────────────────────────────────────────────────────────

# --- App / branding ---
APP_NAME="Avis Budget Group"
APP_URL="https://your-netlify-site.netlify.app"
APP_TIMEZONE="Europe/London"        # anchors "yesterday" + the daily refresh

# NOTE: Every integration key below can also be entered in the dashboard UI
# (Settings → Integrations & API keys). A key saved there is encrypted and
# overrides the matching env var, so these are optional once the app is deployed.

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"      # min 32 chars
# Encrypts API keys saved via the Settings UI. Set a strong value in production.
CREDENTIALS_SECRET="change-me-to-a-long-random-string"
ADMIN_EMAIL="admin@lsdagency.co.uk"   # LSD Agency (full access — push budgets, refresh)
ADMIN_PASSWORD="set-a-strong-password"
CLIENT_EMAIL="team@avisbudget.com"    # Avis team (view-only)
CLIENT_PASSWORD="set-a-strong-password"

# --- Database: Neon Postgres (auto-provisioned by Netlify) ---
# Leave blank on Netlify — @netlify/database provisions and injects the URL.
# Set only for local dev against your own Neon instance.
DATABASE_URL=""

# --- Cron protection (scheduled daily refresh) ---
CRON_SECRET="change-me-to-a-long-random-string"

# --- Meta Ads (dummy until live — sample data used as fallback) ---
META_ACCESS_TOKEN="dummy_replace_me"
META_AD_ACCOUNT_ID="act_000000000000"

# --- Reddit Ads (dummy until live — sample data used as fallback) ---
REDDIT_CLIENT_ID="dummy_replace_me"
REDDIT_CLIENT_SECRET="dummy_replace_me"
REDDIT_AD_ACCOUNT_ID="dummy_replace_me"
REDDIT_ACCESS_TOKEN="dummy_replace_me"   # long-lived token, or refreshed via client credentials

# --- TikTok Ads (dummy until live — sample data used as fallback) ---
TIKTOK_APP_ID="dummy_replace_me"
TIKTOK_APP_SECRET="dummy_replace_me"
TIKTOK_ADVERTISER_ID="dummy_replace_me"
TIKTOK_ACCESS_TOKEN="dummy_replace_me"

# --- AI: Claude (optional — heuristic fallback if absent) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Email: Resend (optional) ---
RESEND_API_KEY=""
RESEND_FROM="reports@lsdagency.co.uk"
